{
  "name": "maiker-cli",
  "version": "0.1.0",
  "description": "mAIker — a local-first AI product engineering CLI",
  "type": "module",
  "bin": {
    "maiker": "./dist/bin/maiker.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx bin/maiker.ts",
    "start": "node dist/bin/maiker.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepare": "npm run build",
    "link:local": "npm run build && npm link",
    "setup": "npm install && npm run build && npm link && echo '\\n✓ maiker installed globally. Run: maiker --help'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "inquirer": "^10.1.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "automation",
    "code-generation",
    "playwright",
    "langgraph",
    "ai-agents"
  ],
  "license": "MIT"
}
