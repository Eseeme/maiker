# mAIker Environment Variables
# Copy this file to .env and fill in your values

# ─── Provider API Keys ────────────────────────────────────────────────────────
# Every agent role is independently configurable in maiker.config.yaml.
# By default all roles use Claude, so you only need ANTHROPIC_API_KEY to start.
# Add other keys only if you switch specific roles to other providers.

# Anthropic Claude — default provider for ALL roles
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — add if you route any role to openai/gpt-4o, openai/o1, openai/codex-mini, etc.
OPENAI_API_KEY=sk-...

# Google Gemini — add if you route research_ingestion or any other role to gemini
GOOGLE_API_KEY=AIza...

# pi-mono (optional, internal routing layer)
PI_MONO_API_KEY=
PI_MONO_BASE_URL=

# ─── Runtime Settings ─────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
MAIKER_LOG_LEVEL=info

# Default config file path
MAIKER_CONFIG_PATH=./maiker.config.yaml

# Run output directory (default: .maiker/runs)
MAIKER_RUNS_DIR=.maiker/runs

# Playwright browser (chromium | firefox | webkit)
PLAYWRIGHT_BROWSER=chromium

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Enable local UI server
MAIKER_UI_ENABLED=false
MAIKER_UI_PORT=4242
